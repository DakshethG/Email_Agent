# Copy to .env and fill in real values. NEVER commit .env (it is git-ignored).
# .env.example documents the required vars only — keep it free of real secrets.

# --- NVIDIA NIM (Mistral Nemotron) ---
# Regenerate this key first — the one shared during planning was exposed.
NVIDIA_API_KEY=nvapi-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NIM_MODEL=mistralai/mistral-nemotron        # verify exact ID on build.nvidia.com
NIM_FALLBACK_MODEL=meta/llama-3.3-70b-instruct

# --- Composio (managed Google + Slack tools) ---
COMPOSIO_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
COMPOSIO_USER_ID=default                     # single personal user_id for connected accounts

# --- Slack (Bolt, Socket Mode) ---
SLACK_BOT_TOKEN=xoxb-xxxxxxxxxxxx            # Bot User OAuth Token
SLACK_APP_TOKEN=xapp-xxxxxxxxxxxx            # App-Level Token for Socket Mode
SLACK_OWNER_USER_ID=Uxxxxxxxx                # only this user may command/approve

# --- App ---
PENDING_DB_PATH=./pending.db                 # SQLite queue (git-ignored)
DEFAULT_TIMEZONE=Asia/Kolkata
